{
  "manifest_version": 3,
  "name": "Kufar.by BYN to USD",
  "version": "1.0.0",
  "description": "Converts Kufar.by ad prices from BYN to USD using NBRB exchange rate.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.kufar.by/*",
    "*://kufar.by/*",
    "https://api.nbrb.by/*",
    "https://www.nbrb.by/*",
    "https://open.er-api.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.kufar.by/*",
        "*://kufar.by/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
